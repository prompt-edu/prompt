# Development Environment Configuration
# Copy this file to .env.dev and fill in your values
#
# This file contains overrides for local development (running Go outside Docker)
# Usage: make server (automatically loads .env then .env.dev)

# Database - use localhost instead of Docker service names, and the host-side
# port mappings from docker-compose.yml instead of the internal 5432.
DB_CORE_HOST=localhost
DB_HOST=localhost
DB_HOST_CERTIFICATE=localhost
DB_PORT_CERTIFICATE=5439
DB_INTERVIEW_HOST=localhost
DB_HOST_INTERVIEW=localhost
DB_INTERVIEW_PORT=5438
DB_PORT_INTERVIEW=5438
DB_TEMPLATE_HOST=localhost
DB_HOST_TEMPLATE_SERVER=localhost
DB_TEMPLATE_PORT=5437
DB_PORT_TEMPLATE_SERVER=5437

# Keycloak - use localhost
KEYCLOAK_HOST=http://localhost:8081

# Keycloak Client Secret - paste your secret here after generating it in Keycloak
# Go to: Keycloak Admin Console → Clients → prompt-server → Credentials → Regenerate
KEYCLOAK_CLIENT_SECRET=

# S3 - use localhost instead of Docker service name (seaweedfs-s3:8333 is Docker-only)
S3_ENDPOINT=http://localhost:8334
S3_PUBLIC_ENDPOINT=http://localhost:8334
S3_REGION=us-east-1
S3_BUCKET=prompt-files
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123
S3_FORCE_PATH_STYLE=true

# Client dev defaults
CLIENT_CORE_HOST=http://localhost:8080
CLIENT_INTRO_COURSE_HOST=http://localhost:8082
CLIENT_DEVOPS_CHALLENGE_HOST=http://localhost:9000
CLIENT_TEAM_ALLOCATION_HOST=http://localhost:8083
CLIENT_SELF_TEAM_ALLOCATION_HOST=http://localhost:8084
CLIENT_ASSESSMENT_HOST=http://localhost:8085
CLIENT_TEMPLATE_HOST=http://localhost:8086
CLIENT_INTERVIEW_HOST=http://localhost:8087
CLIENT_CERTIFICATE_HOST=http://localhost:8088
CLIENT_KEYCLOAK_HOST=http://localhost:8081
GITHUB_SHA=dev
GITHUB_REF=dev
SERVER_CORE_IMAGE_TAG=dev
SENTRY_DSN_CLIENT=

# Debug mode
DEBUG=true
