# Generated run artifacts (reports, fixtures, tokens, raw k6 output) - never commit
reports/

# Generated endpoint catalog: merged from partial_*.json by merge_catalog.py,
# which run.sh invokes before every run. Committing it invites silent drift.
catalog/endpoints.json

# Local Python virtualenv + caches
.venv/
__pycache__/
*.pyc

# Real env file (committed as stress.env.example; copy it to stress.env locally).
# Also covered by the repo-root '**.env' rule, kept here for clarity.
stress.env
