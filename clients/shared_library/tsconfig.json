// DO NOT REMOVE - this is required for eslint and shadcn to be able to add new components
{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist/",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "module": "esnext",
    "target": "es6",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["node"],
    "paths": {
      "@/*": ["../shared_library/*"]
    }
  },
}
