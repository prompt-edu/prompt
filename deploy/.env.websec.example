# ============================================================================
# PROMPT 2.0 - prompt-websec test-prod environment (TEMPLATE)
# ============================================================================
# This file is committed with PLACEHOLDER secrets. On the VM run
#   deploy/render-secrets.sh
# which copies this to deploy/.env.websec and fills every placeholder value
# with a strong random secret. deploy/.env.websec is gitignored.
#
# Public URL: https://prompt-websec.aet.cit.tum.de/  (HTTPS)

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=production
# Full URL WITH scheme: consumed by the Go backend for CORS, mail links and
# inter-service base URLs (NormaliseHost keeps the scheme). Traefik Host() rules
# use the bare domain literally in the compose file, so this MUST carry https://.
CORE_HOST=https://prompt-websec.aet.cit.tum.de

# Used by Traefik for the Let's Encrypt account and certificate-expiry notices.
ACME_EMAIL=prompt-websec@aet.cit.tum.de

CHAIR_NAME_SHORT=PROMPT WebSec
CHAIR_NAME_LONG=PROMPT IT-Security Test Instance

SERVER_ADDRESS=0.0.0.0:8080

# ---------------------------------------------------------------------------
# Core database (generic DB_* vars are what the core server reads)
# ---------------------------------------------------------------------------
DB_CORE_HOST=db
DB_CORE_PORT=5432
DB_CORE_NAME=prompt
DB_CORE_USER=prompt-postgres
DB_CORE_PASSWORD=__GENERATE__

DB_HOST=${DB_CORE_HOST}
DB_PORT=${DB_CORE_PORT}
DB_NAME=${DB_CORE_NAME}
DB_USER=${DB_CORE_USER}
DB_PASSWORD=${DB_CORE_PASSWORD}

# ---------------------------------------------------------------------------
# Per-service databases (share the same user/password; one container each)
# ---------------------------------------------------------------------------
DB_HOST_TEAM_ALLOCATION=db-team-allocation
DB_PORT_TEAM_ALLOCATION=5432
DB_HOST_SELF_TEAM_ALLOCATION=db-self-team-allocation
DB_PORT_SELF_TEAM_ALLOCATION=5432
DB_HOST_ASSESSMENT=db-assessment
DB_PORT_ASSESSMENT=5432
DB_HOST_CERTIFICATE=db-certificate
DB_PORT_CERTIFICATE=5432
DB_HOST_INTERVIEW=db-interview
DB_PORT_INTERVIEW=5432

# Intro-course service (external course-phase module deployed on this VM).
DB_INTRO_COURSE_NAME=intro_course
DB_INTRO_COURSE_USER=intro-course-postgres
DB_INTRO_COURSE_PASSWORD=__GENERATE__
GITLAB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Keycloak (served under the /idp relative path on the single host)
# ---------------------------------------------------------------------------
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=__GENERATE__

KEYCLOAK_HOST=https://prompt-websec.aet.cit.tum.de/idp
KEYCLOAK_REALM_NAME=prompt
KEYCLOAK_CLIENT_ID=prompt-server
# Must match the prompt-server client "secret" in the imported realm. render-secrets.sh
# generates this value AND injects it into keycloakConfig.rendered.json.
KEYCLOAK_CLIENT_SECRET=__GENERATE__
KEYCLOAK_ID_OF_CLIENT=a584ca61-fa83-4e95-98b6-c5f3157ae4b4
KEYCLOAK_AUTHORIZED_PARTY=prompt-client

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__GENERATE__

# ---------------------------------------------------------------------------
# Email / SMTP (non-functional on this VM; mail features will no-op)
# ---------------------------------------------------------------------------
SENDER_EMAIL=prompt-websec@aet.cit.tum.de
SENDER_NAME=PROMPT WebSec Test
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Image tags (latest main builds from GHCR)
# ---------------------------------------------------------------------------
SERVER_CORE_IMAGE_TAG=main
SERVER_TEAM_ALLOCATION_IMAGE_TAG=main
SERVER_SELF_TEAM_ALLOCATION_IMAGE_TAG=main
SERVER_ASSESSMENT_IMAGE_TAG=main
SERVER_INTERVIEW_IMAGE_TAG=main
SERVER_CERTIFICATE_IMAGE_TAG=main

CORE_IMAGE_TAG=main
TEMPLATE_IMAGE_TAG=main
INTERVIEW_IMAGE_TAG=main
MATCHING_IMAGE_TAG=main
ASSESSMENT_IMAGE_TAG=main
TEAM_ALLOCATION_IMAGE_TAG=main
SELF_TEAM_ALLOCATION_IMAGE_TAG=main
CERTIFICATE_IMAGE_TAG=main
INTRO_COURSE_SERVER_IMAGE_TAG=main
INTRO_COURSE_CLIENT_IMAGE_TAG=main
GITHUB_CHALLENGE_IMAGE_TAG=main

# ---------------------------------------------------------------------------
# Module API hosts. Client requests already include the module path, so these
# must remain the bare origin rather than a path-based module URL.
# ---------------------------------------------------------------------------
INTRO_COURSE_HOST=https://prompt-websec.aet.cit.tum.de
DEVOPS_CHALLENGE_HOST=https://prompt-websec.aet.cit.tum.de
TEAM_ALLOCATION_HOST=https://prompt-websec.aet.cit.tum.de
SELF_TEAM_ALLOCATION_HOST=https://prompt-websec.aet.cit.tum.de
ASSESSMENT_HOST=https://prompt-websec.aet.cit.tum.de
TEMPLATE_HOST=https://prompt-websec.aet.cit.tum.de
INTERVIEW_HOST=https://prompt-websec.aet.cit.tum.de
CERTIFICATE_HOST=https://prompt-websec.aet.cit.tum.de

# Inter-service base URL for the core server (internal Docker DNS).
SERVER_CORE_HOST=http://server-core:8080

# Git metadata (display only)
GITHUB_SHA=deploy-prompt-websec
GITHUB_REF=deploy/prompt-websec

# ---------------------------------------------------------------------------
# Sentry (disabled)
# ---------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN_ASSESSMENT=
SENTRY_DSN_CERTIFICATE=
SENTRY_DSN_CLIENT=
SENTRY_DSN_CORE=
SENTRY_DSN_INTERVIEW=
SENTRY_DSN_INTRO_COURSE=
SENTRY_DSN_SELF_TEAM_ALLOCATION=
SENTRY_DSN_TEAM_ALLOCATION=
SENTRY_DSN_TEMPLATE_SERVER=

# ---------------------------------------------------------------------------
# File storage (SeaweedFS S3 gateway). Internal endpoint works; the public
# path-based endpoint is best-effort (presigned-URL signing across /s3 may fail).
# ---------------------------------------------------------------------------
S3_BUCKET=prompt-files
S3_REGION=us-east-1
S3_ENDPOINT=http://seaweedfs-s3:8333
S3_PUBLIC_ENDPOINT=https://prompt-websec.aet.cit.tum.de/s3
S3_ACCESS_KEY=__GENERATE__
S3_SECRET_KEY=__GENERATE__
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_UPLOAD_TTL_SECONDS=60
S3_PRESIGN_DOWNLOAD_TTL_SECONDS=30
MAX_FILE_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/gif,application/zip,text/plain
