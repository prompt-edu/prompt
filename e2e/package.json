{
  "name": "prompt-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for PROMPT 2.0 core server + client",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "merge-reports": "playwright merge-reports --reporter html ./all-blob-reports"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "typescript": "6.0.3"
  }
}
