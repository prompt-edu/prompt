# Copy to .env and adjust. URLs point at a locally running PROMPT dev stack by default.

# PROMPT core
CORE_HOST=http://localhost:3000
SERVER_CORE_HOST=http://localhost:8080

# Keycloak (same instance the PROMPT core uses)
KEYCLOAK_HOST=http://localhost:8081
KEYCLOAK_REALM_NAME=prompt

# Phase database
DB_EXAMPLE_NAME=prompt
DB_EXAMPLE_USER=prompt-postgres
DB_EXAMPLE_PASSWORD=prompt-postgres

# Production only
# PHASE_HOST=phase.example.com
# IMAGE_TAG=latest

DEBUG=false
